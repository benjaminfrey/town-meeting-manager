############
# Secrets
############

# PostgreSQL superuser password — used by all services to connect to the database
POSTGRES_PASSWORD=your-super-secret-db-password

# JWT secret — must be at least 32 characters. All Supabase services share this.
# Generate for production with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Supabase API keys — JWTs signed with JWT_SECRET containing role claims.
# Generate from JWT_SECRET using https://supabase.com/docs/guides/self-hosting#api-keys
# ANON_KEY: { "role": "anon", "iss": "supabase", "iat": 1641769200, "exp": 1799535600 }
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key
# SERVICE_ROLE_KEY: { "role": "service_role", "iss": "supabase", "iat": 1641769200, "exp": 1799535600 }
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

# Studio dashboard credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Realtime secret key base (Erlang/Elixir)
# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters-long-generate-with-openssl

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# API Ports (host-side mappings)
############

# Kong API Gateway — main Supabase API URL
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54329

# PostgreSQL direct access (host-side)
POSTGRES_PORT_HOST=54322

# Studio admin UI
STUDIO_PORT=54323

############
# URLs
############

SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321

############
# Auth (GoTrue)
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true

ADDITIONAL_REDIRECT_URLS=

############
# Email (SMTP)
############

SMTP_ADMIN_EMAIL=admin@townmeetingmanager.local
SMTP_HOST=
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Town Meeting Manager

# Mailer URL paths
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=Town Meeting Manager
STUDIO_DEFAULT_PROJECT=Town Meeting Manager Dev

############
# PostgREST
############

PGRST_DB_SCHEMAS=public,storage

############
# Storage
############

S3_PROTOCOL_ACCESS_KEY_ID=stub
S3_PROTOCOL_ACCESS_KEY_SECRET=stub

############
# PowerSync (added in session 01.04)
############

# Port for PowerSync API (host-side mapping)
POWERSYNC_PORT=8080
