{{! Subject: {{alertTitle}} — {{townName}} Admin Alert }}
<h2 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;color:#1a3a6b;font-weight:normal;">
  {{alertTitle}}
</h2>

<p style="margin:0 0 24px;font-size:13px;color:#6b7280;">{{townName}} — Admin Alert</p>

<p style="margin:0 0 16px;">
  Hi {{recipientName}},
</p>

<div style="background-color:#fefce8;border-left:4px solid #ca8a04;padding:16px 20px;margin:0 0 24px;border-radius:0 4px 4px 0;">
  <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.6;">
    {{{alertMessage}}}
  </p>
</div>

{{#if actionUrl}}
<table cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr>
    <td style="background-color:#1a3a6b;border-radius:4px;padding:12px 28px;">
      <a href="{{actionUrl}}"
         style="color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:15px;font-weight:bold;text-decoration:none;display:block;">
        {{#if actionLabel}}{{actionLabel}}{{else}}Take Action{{/if}}
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:0;font-size:13px;color:#6b7280;">
  This alert was sent to administrators of {{townName}}.
</p>
