{{! Subject: Agenda published — {{boardName}}, {{meetingDate}} }}
<h2 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;color:#1a3a6b;font-weight:normal;">
  Agenda Published
</h2>

<p style="margin:0 0 24px;font-size:13px;color:#6b7280;">{{townName}}</p>

<p style="margin:0 0 16px;">
  Hi {{recipientName}},
</p>

<p style="margin:0 0 24px;">
  The agenda for the <strong>{{boardName}}</strong> meeting on <strong>{{meetingDate}}</strong>
  has been published{{#if itemCount}} with <strong>{{itemCount}} item{{#if (gt itemCount 1)}}s{{/if}}</strong>{{/if}}.
</p>

<!-- Action buttons -->
<table cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr>
    {{#if agendaUrl}}
    <td style="padding-right:12px;">
      <table cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#1a3a6b;border-radius:4px;padding:12px 24px;">
            <a href="{{agendaUrl}}"
               style="color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:bold;text-decoration:none;display:block;">
              View Agenda
            </a>
          </td>
        </tr>
      </table>
    </td>
    {{/if}}
    {{#if portalUrl}}
    <td>
      <table cellpadding="0" cellspacing="0">
        <tr>
          <td style="background-color:#ffffff;border:1px solid #1a3a6b;border-radius:4px;padding:11px 24px;">
            <a href="{{portalUrl}}"
               style="color:#1a3a6b;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:bold;text-decoration:none;display:block;">
              Public Portal
            </a>
          </td>
        </tr>
      </table>
    </td>
    {{/if}}
  </tr>
</table>

<p style="margin:0;font-size:13px;color:#6b7280;">
  You are receiving this because you are associated with the {{boardName}}.
</p>
