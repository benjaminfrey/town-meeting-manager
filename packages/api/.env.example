PORT=3001
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Postmark (email delivery) ─────────────────────────────────────────────
# Create a server at https://account.postmarkapp.com — copy the Server API Token here.
# Each town can override this with a per-town token in town_notification_config.
POSTMARK_SERVER_TOKEN=your-postmark-server-api-token

# ─── App URL (used in email links) ─────────────────────────────────────────
APP_URL=http://localhost:5173

# ─── Postmark Setup Notes ──────────────────────────────────────────────────
# Message streams required on your Postmark server:
#   1. "outbound"  (transactional) — invites, password resets, minutes review, admin alerts
#   2. "broadcast" (broadcast)     — meeting notices, agenda/minutes published
#
# Sender domain:
#   - Verify *.townmeetingmanager.com in Postmark (Sender Signatures → Domain)
#   - Add the SPF, DKIM, and DMARC DNS records Postmark provides
#   - Each town sender (notifications@townname.townmeetingmanager.com) is then valid
