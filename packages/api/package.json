{
  "name": "@town-meeting/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b && cp -r src/templates dist/",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@supabase/supabase-js": "^2.99.0",
    "@town-meeting/shared": "workspace:*",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "handlebars": "^4.7.8",
    "pdf-lib": "^1.17.1",
    "postmark": "^4.0.7",
    "puppeteer": "^24.39.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
