{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*",
    ".react-router/types/**/*",
    "vite.config.ts",
    "react-router.config.ts"
  ],
  "exclude": ["build", "node_modules"],
  "references": [{ "path": "../shared" }]
}
