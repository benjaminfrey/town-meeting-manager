{
  "name": "town-meeting-manager",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "supabase:up": "cd docker && docker compose up -d",
    "supabase:down": "cd docker && docker compose down",
    "supabase:reset": "cd docker && docker compose down -v && docker compose up -d",
    "supabase:logs": "cd docker && docker compose logs -f",
    "supabase:status": "cd docker && docker compose ps",
    "supabase:db": "docker exec -it town-meeting-db psql -U postgres"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.14"
  }
}
