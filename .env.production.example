# ─────────────────────────────────────────────────────────────────────
# Town Meeting Manager — Production environment template
#
# Copy to .env.production and fill in every value. NEVER commit .env.production.
#   cp .env.production.example .env.production
#
# Used by:
#   docker compose --env-file .env.production -f infrastructure/docker-compose.production.yml ...
#
# The VITE_* values are BUILD-TIME — they are baked into the static web
# bundle when you run `pnpm turbo run build`, so they must be present in the
# shell/CI that builds the web app, and must point at the PUBLIC URLs.
# ─────────────────────────────────────────────────────────────────────

# ── Core Supabase secrets ────────────────────────────────────────────
# Strong DB superuser password.
POSTGRES_PASSWORD=
# Shared JWT secret for all Supabase services. Min 32 chars.
#   openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRY=3600
# anon + service_role keys: JWTs signed with JWT_SECRET.
# Generate per https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=
SERVICE_ROLE_KEY=
# Realtime (Elixir) secret base.  openssl rand -base64 48
SECRET_KEY_BASE=
# Realtime DB encryption key (exactly 16 chars).
REALTIME_ENC_KEY=subaserealtime00
# Supabase Studio basic-auth (Studio is also IP-restricted at Nginx).
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# ── Public URLs (drive auth redirects, CORS, and the browser client) ──
SITE_URL=https://app.townmeetingmanager.com
SUPABASE_PUBLIC_URL=https://supabase.townmeetingmanager.com
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false

# ── Auth email (GoTrue SMTP) — a REAL relay, e.g. Postmark ────────────
# Postmark SMTP: host=smtp.postmarkapp.com port=587 user=pass=<server token>.
SMTP_ADMIN_EMAIL=admin@townmeetingmanager.com
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Town Meeting Manager

# ── Fastify API (packages/api) ────────────────────────────────────────
# HMAC key for signed unsubscribe / notification-preference tokens.
#   openssl rand -hex 32
APP_SECRET=
# Postmark server token for transactional + broadcast email.
POSTMARK_SERVER_TOKEN=
# Web Push (PWA). Generate once:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@townmeetingmanager.com

# ── Web app build-time config (VITE_*) — must match the public URLs ───
VITE_SUPABASE_URL=https://supabase.townmeetingmanager.com
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=https://api.townmeetingmanager.com
VITE_VAPID_PUBLIC_KEY=

# ── Nginx static web root (deploy.sh copies build/client/* here) ──────
WEB_ROOT=/var/www/townmeetingmanager/web

# ── TLS / certbot (DNS-01 wildcard challenge) ─────────────────────────
CERTBOT_EMAIL=admin@townmeetingmanager.com
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=

# ── Backups ───────────────────────────────────────────────────────────
BACKUP_PATH=/var/backups/postgres
BACKUP_RETENTION_DAYS=30

# ── Supabase Storage S3 protocol (unused with file backend — leave stub) ─
S3_PROTOCOL_ACCESS_KEY_ID=stub
S3_PROTOCOL_ACCESS_KEY_SECRET=stub
